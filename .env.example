NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OWNER_EMAIL=owner@example.com
NEXT_PUBLIC_SITE_URL=https://www.realpropertyestate.online

# Resend (https://resend.com) — sends an email to OWNER_EMAIL on every
# contact form / property enquiry submission. Without this set, submissions
# still save to Supabase but no email is sent.
RESEND_API_KEY=re_your_api_key
# Must be on a domain you've verified in Resend. Until then, leave unset to
# use Resend's shared onboarding@resend.dev sender (only deliverable to the
# email address your Resend account was signed up with).
RESEND_FROM_EMAIL=Real Property Estate <noreply@realpropertyestate.online>
